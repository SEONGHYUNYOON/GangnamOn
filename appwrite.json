                "databases.main.collections.chat_messages.documents.*.create"
            ],
            "schedule": "",
            "timeout": 60,
            "enabled": true,
            "logging": true,
            "deploymentRetention": 0,
            "buildSpecification": "s-2vcpu-2gb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
            "entrypoint": "src/main.js",
            "commands": "npm install",
            "scopes": [
                "databases.read",
                "databases.write",
                "documents.read",
                "documents.write",
                "users.read",
                "users.write"
            ],
            "path": "functions/economy"
        },
        {
